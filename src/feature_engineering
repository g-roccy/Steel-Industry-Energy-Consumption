import pandas as pd\nimport numpy as np\n\nclass FeatureEngineering:\n    def __init__(self, data):\n        self.data = data\n\n    def create_lag_features(self, lag_periods):\n        for lag in lag_periods:\n            self.data[f'lag_{lag}'] = self.data['energy_consumption'].shift(lag)\n\n    def create_rolling_features(self, window_sizes):\n        for window in window_sizes:\n            self.data[f'rolling_mean_{window}'] = self.data['energy_consumption'].rolling(window=window).mean()\n            self.data[f'rolling_std_{window}'] = self.data['energy_consumption'].rolling(window=window).std()\n\n    def create_temporal_features(self):\n        self.data['year'] = self.data['date'].dt.year\n        self.data['month'] = self.data['date'].dt.month\n        self.data['day'] = self.data['date'].dt.day\n        self.data['weekday'] = self.data['date'].dt.weekday\n\n    def normalize_features(self):\n        self.data['energy_consumption'] = (self.data['energy_consumption'] - self.data['energy_consumption'].mean()) / self.data['energy_consumption'].std()\n\n    def process_data(self, lag_periods, window_sizes):\n        self.create_lag_features(lag_periods)\n        self.create_rolling_features(window_sizes)\n        self.create_temporal_features()\n        self.normalize_features()\n        return self.data\n
